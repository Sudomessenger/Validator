# Default network settings for one-command validator join.
# Override with environment variables or edit before running join-validator.sh

CHAIN_ID=sudo99
SEED_NODE_ID=6eafed75e8db7b0eed2f608b211afde9f71de184
SEED_IP=170.64.178.165
SEED_P2P_PORT=26656
PUBLIC_RPC=https://rpc.sudoscan.io
# CometBFT RPC for broadcasting txs (must include host:port — not HTTPS URL)
PUBLIC_TX_NODE=tcp://170.64.178.165:26657
# Genesis: join-validator fetches live genesis from PUBLIC_TX_NODE / SEED_IP first.
# Bundled config/genesis.sudo99.json is fallback only (may be stale after chain recovery).
STAKE_SUDO=1000
FEE_BUFFER_SUDO=1

# Pre-built sudod download (standalone — no Sudomessenger/network repo needed)
SUDOD_DOWNLOAD_URL=https://github.com/Sudomessenger/Validator/releases/download/v1.0.1/sudod-linux-amd64
WASMVM_DOWNLOAD_URL=https://github.com/Sudomessenger/Validator/releases/download/v1.0.1/libwasmvm.x86_64.so
