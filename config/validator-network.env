# Default network settings for one-command validator join.
# Override with environment variables or edit before running join-validator.sh

CHAIN_ID=sudo99
SEED_NODE_ID=6eafed75e8db7b0eed2f608b211afde9f71de184
SEED_IP=170.64.178.165
SEED_P2P_PORT=26656
PUBLIC_RPC=https://rpc.sudoscan.io
PUBLIC_TX_NODE=tcp://170.64.178.165:26657
STAKE_SUDO=1000
FEE_BUFFER_SUDO=1

# Pre-built sudod download (standalone — no Sudomessenger/network repo needed)
SUDOD_DOWNLOAD_URL=https://github.com/Sudomessenger/Validator/releases/download/v1.0.0/sudod-linux-amd64
# libwasmvm ships bundled in repo lib/ — optional release URL fallback:
WASMVM_DOWNLOAD_URL=https://github.com/Sudomessenger/Validator/releases/download/v1.0.1/libwasmvm.x86_64.so

# State sync (default ON) — new validators sync in ~5-15 min instead of hours.
# Requires seed snapshots: bash scripts/enable-seed-snapshots.sh (run once on seed server).
USE_STATE_SYNC=1
STATE_SYNC_TRUST_OFFSET=2000
STATE_SYNC_TRUST_PERIOD=168h0m0s
STATE_SYNC_SNAPSHOT_INTERVAL=1000
STATE_SYNC_SNAPSHOT_KEEP=5
# Optional override (comma-separated, need 2 endpoints — auto-built from seed + rpc if empty):
# STATE_SYNC_RPC_SERVERS=http://170.64.178.165:26657,https://rpc.sudoscan.io
