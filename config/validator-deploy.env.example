# Production validator credentials — copy to validator-deploy.env and fill in.
# NEVER commit validator-deploy.env to git.
#
# cp validator-deploy.env.example validator-deploy.env
# chmod 600 validator-deploy.env

# Wallet (use ONE of these):
# VALIDATOR_PRIVATE_KEY=0xYOUR_HEX_PRIVATE_KEY
# VALIDATOR_MNEMONIC="word1 word2 ... word24"

# Validator display name (explorer / moniker)
MONIKER=my-validator

# Node home directory
VALIDATOR_HOME=/opt/sudo-validator

# Key name in keyring (default: validator)
KEY_NAME=validator

# Network (defaults match sudo99 mainnet — usually no change needed)
# SEED_IP=170.64.178.165
# CHAIN_ID=sudo99

# Optional: restore consensus keys from tarball (same validator redeploy after VPS reset)
# VALIDATOR_CONFIG_BACKUP=/path/to/priv_validator_backup.tar.gz
# Or auto-fetch from seed if backup exists at:
# VALIDATOR_CONFIG_BACKUP_PATH=/root/sudo-backups/vps-validator-config-latest.tar.gz
